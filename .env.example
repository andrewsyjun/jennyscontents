# Copy this file to .env and fill values locally.
# Never commit .env. The repo's .gitignore already excludes it.

# X API
# Create at https://console.x.com/
X_BEARER_TOKEN=
X_USERNAME=

# Instagram API with Instagram Login
# Create at https://developers.facebook.com/ and add the Instagram product.
META_GRAPH_VERSION=v25.0
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_USERNAME=

# TikTok Display API
# Create at https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=
TIKTOK_USERNAME=

# Optional TikTok Research API for broader public trend research.
# This requires separate approval for non-commercial or academic research.
TIKTOK_RESEARCH_CLIENT_KEY=
TIKTOK_RESEARCH_CLIENT_SECRET=
