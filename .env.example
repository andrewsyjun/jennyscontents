# Copy this file to .env and fill values locally.
# Never commit .env. The repo's .gitignore already excludes it.

# Local app
LOCAL_PORT=4173
LOCAL_APP_URL=http://127.0.0.1:4173

# X API
# Create at https://console.x.com/
X_BEARER_TOKEN=
X_USERNAME=
# Optional. Recent search may consume X API usage/credits.
X_CHECK_RECENT_SEARCH=false
X_RECENT_SEARCH_QUERY='("real estate" OR realtor OR homebuyer OR homeseller) lang:en -is:retweet'
X_RECENT_SEARCH_MAX_RESULTS=10

# Instagram API with Instagram Login
# Create at https://developers.facebook.com/ and add the Instagram product.
META_GRAPH_VERSION=v25.0
# Needed for the local Facebook Login OAuth helper.
META_APP_ID=
META_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4173/auth/facebook/callback
FACEBOOK_LOGIN_SCOPES=instagram_basic,pages_show_list,pages_read_engagement
# Use instagram_login for Instagram API with Instagram Login.
# Use facebook_login for Instagram API with Facebook Login / Facebook Login for Business.
INSTAGRAM_AUTH_MODE=instagram_login
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_USERNAME=
# Optional. Useful when discovering an Instagram account through its connected Facebook Page.
INSTAGRAM_PAGE_ID=

# TikTok Display API
# Create at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:4173/auth/tiktok/callback
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_USERNAME=
TIKTOK_VIDEO_LIST_MAX_COUNT=10
TIKTOK_USER_FIELDS=open_id,avatar_url,display_name

# Optional TikTok Research API for broader public trend research.
# This requires separate approval for non-commercial or academic research.
TIKTOK_RESEARCH_CLIENT_KEY=
TIKTOK_RESEARCH_CLIENT_SECRET=

# Daily content strategy runner
CONTENT_MARKET=North Dallas and DFW
CONTENT_OUTPUT_DIR=content-strategy
CONTENT_ANALYTICS_FILE=data/analytics-notes.md
MANUAL_TRENDS_FILE=data/manual-trends.json
INSTAGRAM_HASHTAG_DISCOVERY=false
INSTAGRAM_HASHTAGS=dfwrealestate,dallasrealestate,northdallas,dallasrealtor,dfwrealtor,planotx,friscotx,mckinneytx,realtor,realestateagent,homebuyer,homeseller,firsttimehomebuyer,listingagent,openhouse
INSTAGRAM_HASHTAG_LIMIT=5
INSTAGRAM_INSIGHT_METRICS=views,reach,saved,shares

# Google Drive upload. Create an OAuth client and store these locally or as GitHub Actions secrets.
GOOGLE_DRIVE_UPLOAD=false
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CONTENT_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_PORT=8787
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth2callback
